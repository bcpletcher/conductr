# Orqis — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required for Claude task execution)
ANTHROPIC_API_KEY=sk-ant-...

# OpenClaw MCP (optional — for agent orchestration, Phase 2)
OPENCLAW_API_KEY=
OPENCLAW_BASE_URL=

# Font Awesome Pro (optional — set token for Pro icon access)
# Export this before `npm install` if using Pro: export FONTAWESOME_PACKAGE_TOKEN=xxx
FONTAWESOME_PACKAGE_TOKEN=

# App settings
NODE_ENV=development
